{
  "expo": {
    "name": "Chopped Scanner",
    "slug": "chopped",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "chopped",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "android": {
      "package": "ch.pianonic.chopped",
      "adaptiveIcon": {
        "backgroundColor": "#0b0b0f",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.CAMERA", "android.permission.READ_MEDIA_IMAGES"]
    },
    "ios": {
      "bundleIdentifier": "ch.pianonic.chopped",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Used to take a selfie to rate.",
        "NSPhotoLibraryUsageDescription": "Used to pick a photo to rate."
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "Chopped Scanner",
      "shortName": "Chopped",
      "themeColor": "#0b0b0f",
      "backgroundColor": "#0b0b0f",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0b0b0f",
          "dark": {
            "backgroundColor": "#0b0b0f"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Used to take a selfie to rate.",
          "photosPermission": "Used to pick a photo to rate."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
